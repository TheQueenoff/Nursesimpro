  // ═══════════════════════════════════════════
  // RENDER COMPÉTENCES
  // ═══════════════════════════════════════════
  function renderComps() {
    const container = document.getElementById('comp-chips');
    container.innerHTML = Object.entries(COMPETENCES).map(([num, text]) => `
      <label class="comp-chip" id="chip-${num}" onclick="toggleChip(${num})">
        <div class="comp-chip-box">✓</div>
        <div>
          <div class="comp-chip-num">Compétence ${num}</div>
          <div class="comp-chip-text">${text}</div>
        </div>
      </label>
    `).join('');
  }

  function toggleChip(num) {
    const el = document.getElementById('chip-' + num);
    const idx = selectedComps.indexOf(num);
    if (idx > -1) {
      selectedComps.splice(idx, 1);
      el.classList.remove('checked');
    } else {
      selectedComps.push(num);
      el.classList.add('checked');
    }
  }

  // ═══════════════════════════════════════════
  // CALCUL DU NOMBRE D'ACTES SELON DURÉE
  // ═══════════════════════════════════════════
  function getMesure(duree) {
    // Plus le stage est long, plus le nombre d'actes attendu est élevé
    if (duree <= 5) return 2;
    if (duree <= 10) return 3;
    return 5;
  }

  // ═══════════════════════════════════════════
  // GÉNÉRATION
  // ═══════════════════════════════════════════
  function generate() {
    if (selectedComps.length === 0) {
      alert("Coche au moins une compétence à valider.");
      return;
    }

    const service = document.getElementById('f-service').value;
    const duree = parseInt(document.getElementById('f-duree').value) || 10;
    const annee = document.getElementById('f-annee').value;
    const ctx = SERVICE_CONTEXT[service];
    const n = getMesure(duree);

    // Meta
    document.getElementById('results-meta').textContent = 
      `Stage de ${ctx.nom} · ${duree} semaines · ${selectedComps.length} compétence(s) ciblée(s)`;

    // Générer les objectifs
    const comps = [...selectedComps].sort((a,b) => a-b);
    const container = document.getElementById('objectives-container');
    
    container.innerHTML = comps.map(num => {
      const objs = OBJECTIFS[num] || [];
      const items = objs.map(obj => {
        let text = obj.template
          .replace(/{n}/g, n)
          .replace(/{patients}/g, ctx.patients)
          .replace(/{service}/g, ctx.nom)
          .replace(/{actes}/g, ctx.actes);
        return `
          <div class="obj-item">
            <div class="obj-phase">${obj.phase}</div>
            <div class="obj-text">${text}</div>
            <div class="obj-smart">✓ Objectif SMART : spécifique, mesurable, temporel</div>
          </div>
        `;
      }).join('');

      // Actes concrets pour cette compétence
      const actes = ACTES[num] || [];
      const actesHtml = actes.length ? `
        <div class="actes-box">
          <div class="actes-title">🩺 Actes concrets qui valident cette compétence</div>
          <div class="actes-list">
            ${actes.map(a => `<div class="acte-item">${a}</div>`).join('')}
          </div>
        </div>
      ` : '';

      return `
        <div class="obj-group">
          <div class="obj-group-head">
            <div class="obj-badge">${num}</div>
            <div class="obj-group-title">${COMPETENCES[num]}</div>
          </div>
          ${items}
          ${actesHtml}
        </div>
      `;
    }).join('');

    // Afficher résultats
    document.getElementById('form-screen').style.display = 'none';
    document.getElementById('results-screen').classList.add('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function restart() {
    document.getElementById('results-screen').classList.remove('show');
    document.getElementById('form-screen').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function goToSite() {
    window.open('https://nursesim-pro.com', '_blank');
  }

  // INIT
