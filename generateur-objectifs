<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Générateur d'Objectifs de Stage · L'École des Infirmiers</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Space+Grotesk:wght@400;500;600;700&display=swap');
  
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  :root {
    --navy: #0a1929;
    --navy-soft: #1e3a5f;
    --navy-light: #e8eef5;
    --white: #ffffff;
    --cream: #faf8f3;
    --gold: #c8a85b;
    --gold-light: #f5e6b8;
    --green: #2d7a4f;
    --green-light: #d4f1e0;
    --grey: #6b7280;
    --grey-light: #d1d5db;
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'Space Grotesk', sans-serif;
  }
  
  body {
    font-family: var(--sans);
    background: var(--cream);
    color: var(--navy);
    min-height: 100vh;
    padding: 20px 16px 60px;
    line-height: 1.5;
  }
  .container { max-width: 780px; margin: 0 auto; }
  
  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 28px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--grey-light);
  }
  .brand {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--navy);
    padding: 6px 14px;
    border: 1px solid var(--navy);
    margin-bottom: 16px;
  }
  h1 {
    font-family: var(--serif);
    font-size: 38px;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin-bottom: 8px;
  }
  h1 em { font-style: italic; color: var(--gold); font-weight: 400; }
  .tagline {
    font-family: var(--serif);
    font-style: italic;
    color: var(--grey);
    font-size: 16px;
    margin-top: 8px;
  }
  .free-badge {
    display: inline-block;
    background: var(--green);
    color: var(--white);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-top: 14px;
  }
  
  /* CARD */
  .card {
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-radius: 6px;
    padding: 24px;
    margin-bottom: 20px;
  }
  .card-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 4px;
    letter-spacing: -0.5px;
  }
  .card-subtitle {
    font-family: var(--serif);
    font-style: italic;
    color: var(--grey);
    font-size: 14px;
    margin-bottom: 20px;
  }
  
  /* FIELDS */
  .field { margin-bottom: 18px; }
  .field label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 7px;
  }
  input, select {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid var(--grey-light);
    border-radius: 3px;
    font-family: var(--sans);
    font-size: 15px;
    color: var(--navy);
    background: var(--white);
    transition: all 0.15s;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--navy);
    background: var(--cream);
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  
  /* COMPETENCES CHIPS */
  .comp-chips { display: flex; flex-direction: column; gap: 8px; }
  .comp-chip {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 14px;
    background: var(--cream);
    border: 1.5px solid var(--grey-light);
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .comp-chip:hover { border-color: var(--navy); }
  .comp-chip.checked { border-color: var(--green); background: var(--green-light); }
  .comp-chip-box {
    width: 22px; height: 22px;
    border: 2px solid var(--grey-light);
    border-radius: 4px;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: var(--white);
    transition: all 0.15s; margin-top: 1px;
  }
  .comp-chip.checked .comp-chip-box { background: var(--green); border-color: var(--green); }
  .comp-chip-num {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 2px;
  }
  .comp-chip-text { font-size: 13px; line-height: 1.4; }
  
  /* BUTTON */
  .btn {
    width: 100%;
    background: var(--navy);
    color: var(--white);
    border: none;
    padding: 16px 24px;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.15s;
  }
  .btn:hover { background: var(--navy-soft); transform: translateY(-1px); }
  .btn-gold { background: var(--gold); color: var(--navy); }
  .btn-gold:hover { background: var(--gold-light); }
  
  /* RESULTS */
  .results { display: none; }
  .results.show { display: block; }
  
  .results-header {
    background: var(--navy);
    color: var(--white);
    border-radius: 6px;
    padding: 22px 24px;
    margin-bottom: 20px;
  }
  .results-header-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 6px;
  }
  .results-header-meta {
    font-size: 13px;
    color: rgba(255,255,255,0.75);
  }
  
  .obj-group { margin-bottom: 24px; }
  .obj-group-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .obj-badge {
    background: var(--navy);
    color: var(--white);
    width: 34px; height: 34px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-weight: 600; font-size: 15px;
    flex-shrink: 0;
  }
  .obj-group-title {
    font-size: 13px; font-weight: 600; line-height: 1.3;
  }
  
  .obj-item {
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-left: 4px solid var(--gold);
    border-radius: 4px;
    padding: 14px 16px;
    margin-bottom: 10px;
  }
  .obj-phase {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 5px;
  }
  .obj-text {
    font-size: 14px;
    line-height: 1.55;
    color: var(--navy);
  }
  .obj-smart {
    margin-top: 8px;
    font-size: 11px;
    color: var(--grey);
    font-style: italic;
    font-family: var(--serif);
  }
  
  /* ACTES CONCRETS */
  .actes-box {
    background: var(--navy-light);
    border: 1px solid var(--navy-soft);
    border-radius: 4px;
    padding: 16px 18px;
    margin-top: 12px;
  }
  .actes-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--navy);
    margin-bottom: 12px;
  }
  .actes-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .acte-item {
    font-size: 12.5px;
    color: var(--navy);
    padding: 8px 10px 8px 26px;
    background: var(--white);
    border-radius: 3px;
    position: relative;
    line-height: 1.35;
  }
  .acte-item::before {
    content: '○';
    position: absolute;
    left: 10px;
    top: 8px;
    color: var(--gold);
    font-weight: 700;
  }
  @media (max-width: 600px) {
    .actes-list { grid-template-columns: 1fr; }
  }
  
  /* PREMIUM CTA */
  .premium-cta {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-soft) 100%);
    color: var(--white);
    padding: 28px 24px;
    border-radius: 6px;
    margin-top: 28px;
    text-align: center;
  }
  .premium-cta-label {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    padding: 5px 14px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 2px;
    margin-bottom: 14px;
  }
  .premium-cta-title {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 500;
    margin-bottom: 10px;
    line-height: 1.15;
  }
  .premium-cta-title em { color: var(--gold); font-style: italic; }
  .premium-cta-desc {
    font-family: var(--serif);
    font-style: italic;
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    margin-bottom: 18px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }
  .premium-features-mini {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    max-width: 440px;
    margin: 0 auto 20px;
    text-align: left;
  }
  .premium-feature-mini {
    font-size: 12px;
    color: rgba(255,255,255,0.9);
    display: flex; align-items: center; gap: 6px;
  }
  .premium-feature-mini::before { content: '✦'; color: var(--gold); }
  
  .actions-row {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }
  .btn-secondary {
    flex: 1;
    background: var(--white);
    color: var(--navy);
    border: 1.5px solid var(--navy);
    padding: 14px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.15s;
  }
  .btn-secondary:hover { background: var(--navy-light); }
  
  /* DISCLAIMER */
  .disclaimer {
    background: var(--green-light);
    border: 1px solid var(--green);
    border-left: 4px solid var(--green);
    padding: 14px 18px;
    margin-bottom: 24px;
    font-size: 12px;
    color: #14532d;
    line-height: 1.6;
    border-radius: 2px;
  }
  .disclaimer strong {
    display: block;
    margin-bottom: 4px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-size: 10px;
    font-weight: 700;
  }
  
  /* FOOTER */
  .footer {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--grey-light);
    text-align: center;
    font-size: 11px;
    color: var(--grey);
    line-height: 1.7;
  }
  
  /* RESPONSIVE */
  @media (max-width: 600px) {
    body { padding: 16px 12px 40px; }
    h1 { font-size: 30px; }
    .card { padding: 18px 16px; }
    .field-row { grid-template-columns: 1fr; }
    .premium-features-mini { grid-template-columns: 1fr; }
    .actions-row { flex-direction: column; }
  }
  @media (max-width: 400px) {
    body { padding: 12px 8px 30px; overflow-x: hidden; }
    * { max-width: 100%; box-sizing: border-box; }
    h1 { font-size: 25px; }
    .premium-cta-title { font-size: 22px; }
  }
</style>
</head>
<body>

<div class="container">

  <header class="header">
    <div class="brand">L'École des Infirmiers</div>
    <h1>Générateur d'<em>Objectifs</em> de Stage</h1>
    <div class="tagline">« Des objectifs SMART prêts pour ton portfolio, en 30 secondes »</div>
    <div class="free-badge">✦ 100% Gratuit</div>
  </header>

  <!-- FORMULAIRE -->
  <div id="form-screen">
    <div class="disclaimer">
      <strong>📔 Comment ça marche</strong>
      Indique ton lieu de stage, sa durée et les compétences que tu veux valider. On te génère des <strong>objectifs personnalisés au format SMART</strong> (Spécifique, Mesurable, Atteignable, Réaliste, Temporel), prêts à recopier dans ton portfolio. Aucune inscription, rien n'est enregistré.<br><br>
      <span style="font-size:11px;opacity:0.85;">📌 Basé sur le <strong>référentiel 2009</strong> (10 compétences) — celui des étudiants entrés avant septembre 2026. La version nouveau référentiel (13 compétences) arrive pour la rentrée.</span>
    </div>

    <div class="card">
      <div class="card-title">Ton stage</div>
      <div class="card-subtitle">Quelques infos pour personnaliser tes objectifs</div>
      
      <div class="field">
        <label>Type de service</label>
        <select id="f-service">
          <optgroup label="Court séjour — Médecine">
            <option value="medecine">Médecine générale / interne</option>
            <option value="cardiologie">Cardiologie</option>
            <option value="pneumologie">Pneumologie</option>
            <option value="neurologie">Neurologie</option>
            <option value="oncologie">Oncologie / Hématologie</option>
            <option value="nephrologie">Néphrologie</option>
            <option value="diabetologie">Endocrinologie / Diabétologie</option>
            <option value="gastro">Gastro-entérologie</option>
          </optgroup>
          <optgroup label="Court séjour — Chirurgie">
            <option value="chirurgie">Chirurgie (générale)</option>
            <option value="chirurgie_ambu">Chirurgie ambulatoire</option>
            <option value="orthopedie">Orthopédie / Traumatologie</option>
            <option value="bloc">Bloc opératoire</option>
          </optgroup>
          <optgroup label="Soins critiques & Urgences">
            <option value="urgences">Urgences</option>
            <option value="reanimation">Réanimation / Soins intensifs</option>
          </optgroup>
          <optgroup label="Mère & Enfant">
            <option value="maternite">Maternité / Obstétrique</option>
            <option value="pediatrie">Pédiatrie</option>
            <option value="neonatologie">Néonatologie</option>
            <option value="pedopsychiatrie">Pédopsychiatrie</option>
          </optgroup>
          <optgroup label="Personnes âgées & Rééducation (longue durée)">
            <option value="geriatrie">Gériatrie</option>
            <option value="ehpad">EHPAD</option>
            <option value="ssr">SSR / Rééducation</option>
            <option value="soins_palliatifs">Soins palliatifs</option>
          </optgroup>
          <optgroup label="Santé mentale">
            <option value="psychiatrie">Psychiatrie</option>
            <option value="addictologie">Addictologie</option>
          </optgroup>
          <optgroup label="Lieux de vie & Soins de ville">
            <option value="domicile">Soins à domicile</option>
            <option value="ssiad">SSIAD</option>
            <option value="liberal">Cabinet libéral</option>
            <option value="hemodialyse">Centre de dialyse</option>
            <option value="sante_travail">Santé au travail / scolaire</option>
          </optgroup>
          <optgroup label="Autre">
            <option value="autre">Autre service</option>
          </optgroup>
        </select>
      </div>
      
      <div class="field-row">
        <div class="field">
          <label>Durée (semaines)</label>
          <input type="number" id="f-duree" placeholder="10" min="1" max="20" value="10" />
        </div>
        <div class="field">
          <label>Ton année</label>
          <select id="f-annee">
            <option value="1">1ère année (S1-S2)</option>
            <option value="2" selected>2ème année (S3-S4)</option>
            <option value="3">3ème année (S5-S6)</option>
          </select>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Compétences à valider</div>
      <div class="card-subtitle">Coche celles que tu veux travailler (1 à 4 recommandé)</div>
      <div class="comp-chips" id="comp-chips"></div>
    </div>

    <button class="btn btn-gold" onclick="generate()">✨ Générer mes objectifs de stage</button>
  </div>

  <!-- RÉSULTATS -->
  <div class="results" id="results-screen">
    <div class="results-header">
      <div class="results-header-title">Tes objectifs de stage</div>
      <div class="results-header-meta" id="results-meta">—</div>
    </div>

    <div id="objectives-container"></div>

    <!-- PREMIUM CTA -->
    <div class="premium-cta">
      <div class="premium-cta-label">Va plus loin</div>
      <div class="premium-cta-title">Et si on t'accompagnait <em>tout au long</em> de ton stage ?</div>
      <div class="premium-cta-desc">Ces objectifs ne sont qu'un début. Le Carnet de Stage complet te guide jour après jour pour les atteindre.</div>
      <div class="premium-features-mini">
        <div class="premium-feature-mini">Carnet de bord quotidien</div>
        <div class="premium-feature-mini">Suivi de tes compétences</div>
        <div class="premium-feature-mini">100 actes par compétence</div>
        <div class="premium-feature-mini">Bilan mi-stage ajustable</div>
        <div class="premium-feature-mini">Compte-rendu final PDF</div>
        <div class="premium-feature-mini">Suivi de ton bien-être</div>
      </div>
      <button class="btn btn-gold" onclick="goToSite()" style="max-width:340px;margin:0 auto;">Découvrir NurseSimPro →</button>
    </div>

    <div class="actions-row">
      <button class="btn-secondary" onclick="window.print()">📥 Imprimer mes objectifs</button>
      <button class="btn-secondary" onclick="restart()">↻ Recommencer</button>
    </div>
  </div>

  <footer class="footer">
    <strong>L'École des Infirmiers · NurseSimPro</strong><br>
    Générateur d'objectifs · Méthode SMART · Référentiel infirmier 2009<br>
    Outil pédagogique gratuit · Aucune donnée enregistrée
  </footer>

</div>

<script>
  // ═══════════════════════════════════════════
  // LES 10 COMPÉTENCES
  // ═══════════════════════════════════════════
  const COMPETENCES = {
    1: "Évaluer une situation clinique et établir un diagnostic infirmier",
    2: "Concevoir et conduire un projet de soins infirmiers",
    3: "Accompagner une personne dans ses soins quotidiens",
    4: "Mettre en œuvre des actions diagnostiques et thérapeutiques",
    5: "Initier et mettre en œuvre des soins éducatifs et préventifs",
    6: "Communiquer et conduire une relation dans un contexte de soins",
    7: "Analyser la qualité des soins et améliorer sa pratique",
    8: "Rechercher et traiter des données professionnelles et scientifiques",
    9: "Organiser et coordonner des interventions soignantes",
    10: "Informer et former des professionnels et personnes en formation"
  };

  // ═══════════════════════════════════════════
  // BANQUE D'OBJECTIFS — par compétence × service
  // Format SMART (verbe d'action + critère + délai)
  // ═══════════════════════════════════════════
  // Chaque objectif a : {action, mesure, contexte par service}
  
  // Contexte clinique par service (pour personnaliser)
  const SERVICE_CONTEXT = {
    medecine: { nom: "médecine", patients: "patients polypathologiques", actes: "perfusions, surveillance, traitements per os" },
    cardiologie: { nom: "cardiologie", patients: "patients cardiaques", actes: "ECG, surveillance scope, gestion des anticoagulants" },
    pneumologie: { nom: "pneumologie", patients: "patients insuffisants respiratoires", actes: "oxygénothérapie, aérosols, surveillance SpO2" },
    neurologie: { nom: "neurologie", patients: "patients neurologiques (AVC, SEP, Parkinson)", actes: "surveillance neurologique, score de Glasgow, prévention des complications" },
    oncologie: { nom: "oncologie / hématologie", patients: "patients atteints de cancer", actes: "chimiothérapie, chambre implantable, soins de support" },
    nephrologie: { nom: "néphrologie / dialyse", patients: "patients insuffisants rénaux", actes: "surveillance de dialyse, gestion des abords vasculaires, bilan hydrique" },
    diabetologie: { nom: "endocrinologie / diabétologie", patients: "patients diabétiques", actes: "glycémies, insulinothérapie, éducation thérapeutique" },
    gastro: { nom: "gastro-entérologie", patients: "patients digestifs", actes: "surveillance de sonde, soins de stomie, préparation aux examens" },
    chirurgie: { nom: "chirurgie", patients: "patients en pré et post-opératoire", actes: "pansements, surveillance post-op, gestion de la douleur" },
    chirurgie_ambu: { nom: "chirurgie ambulatoire", patients: "patients opérés en ambulatoire", actes: "préparation pré-op, surveillance post-op courte, éducation à la sortie" },
    orthopedie: { nom: "orthopédie / traumatologie", patients: "patients opérés de l'appareil locomoteur", actes: "surveillance de plâtre/attelle, prévention thrombo-embolique, rééducation précoce" },
    maternite: { nom: "maternité / obstétrique", patients: "femmes enceintes et jeunes mamans", actes: "surveillance materno-fœtale, soins post-partum, accompagnement à l'allaitement" },
    urgences: { nom: "urgences", patients: "patients en situation aiguë", actes: "tri, gestes d'urgence, surveillance rapprochée" },
    reanimation: { nom: "réanimation / soins intensifs", patients: "patients en défaillance vitale", actes: "surveillance scope, gestion de ventilation, soins techniques lourds" },
    pediatrie: { nom: "pédiatrie", patients: "enfants et leurs familles", actes: "calculs de doses pédiatriques, communication adaptée" },
    neonatologie: { nom: "néonatologie", patients: "nouveau-nés", actes: "surveillance du nourrisson, soins de développement, accompagnement parental" },
    geriatrie: { nom: "gériatrie", patients: "personnes âgées dépendantes", actes: "prévention des chutes, soins d'hygiène, autonomie" },
    ehpad: { nom: "EHPAD", patients: "résidents âgés", actes: "soins quotidiens, prévention des chutes, accompagnement de la dépendance" },
    ssr: { nom: "SSR / rééducation", patients: "patients en convalescence", actes: "rééducation, réautonomisation, suivi pluridisciplinaire" },
